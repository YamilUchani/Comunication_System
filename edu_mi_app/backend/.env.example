# Variables de entorno para el backend
# Copia este archivo como .env y completa los valores

# Puerto del servidor
PORT=3000

# Supabase
SUPABASE_URL=tu_url_de_supabase
SUPABASE_SERVICE_KEY=tu_service_key_de_supabase

# Agora
AGORA_APP_ID=tu_app_id_de_agora
AGORA_APP_CERTIFICATE=tu_certificado_de_agora

# Configuración de tokens de Agora
TOKEN_EXPIRATION_TIME=3600

# Entorno (development, production)
NODE_ENV=development

# CORS - Dominios permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
