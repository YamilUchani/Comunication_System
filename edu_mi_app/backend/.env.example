# Variables de entorno para el backend
# Copia este archivo como .env y completa los valores

# Puerto del servidor
PORT=3000

# Supabase
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Agora
AGORA_APP_ID=YOUR_AGORA_APP_ID
AGORA_APP_CERTIFICATE=YOUR_AGORA_APP_CERTIFICATE

# Configuración de tokens de Agora
TOKEN_EXPIRATION_TIME=3600

# Entorno (development, production)
NODE_ENV=development

# CORS - Dominios permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# IMPORTANTE PARA RAILWAY:
# Los logs se escribirán en backend/logs/ (ya está en .gitignore)
# Railway puede acceder a estos logs vía su dashboard en "Deployments" → "View Logs"
# El logger de Winston escribe en: logs/combined.log y logs/error.log
